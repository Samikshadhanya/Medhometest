rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userHouseholdIds() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc().data.householdIds is list
        ? userDoc().data.householdIds
        : [];
    }

    function belongsToHousehold(householdId) {
      return signedIn() && householdId in userHouseholdIds();
    }

    match /users/{userId} {
      allow read, update: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /households/{householdId} {
      allow read: if belongsToHousehold(householdId);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /medicines/{medicineId} {
      allow read: if belongsToHousehold(resource.data.householdId);
      allow create: if belongsToHousehold(request.resource.data.householdId);
      allow update, delete: if belongsToHousehold(resource.data.householdId);
    }

    match /reminders/{reminderId} {
      allow read: if belongsToHousehold(resource.data.householdId);
      allow create: if belongsToHousehold(request.resource.data.householdId);
      allow update, delete: if belongsToHousehold(resource.data.householdId);
    }

    match /members/{memberId} {
      allow read: if belongsToHousehold(resource.data.householdId);
      allow create: if belongsToHousehold(request.resource.data.householdId);
      allow update, delete: if belongsToHousehold(resource.data.householdId);
    }

    match /caregivers/{caregiverId} {
      allow read: if belongsToHousehold(resource.data.householdId);
      allow create: if belongsToHousehold(request.resource.data.householdId);
      allow update, delete: if belongsToHousehold(resource.data.householdId);
    }
  }
}
