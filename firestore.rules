rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userHouseholdIds() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc().data.householdIds is list
        ? userDoc().data.householdIds
        : [];
    }

    function belongsToHousehold(householdId) {
      return signedIn() && householdId in userHouseholdIds();
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      // SECURITY FIX: Prevent householdIds self-escalation.
      // affectedKeys() alone was bypassable via the REST API PATCH.
      // Now we ALSO assert the incoming householdIds must equal the stored value.
      // If the document has no householdIds yet, only allow setting it to an empty list.
      allow update: if signedIn()
                    && request.auth.uid == userId
                    && (
                         // householdIds field not present in incoming data at all
                         !('householdIds' in request.resource.data)
                         ||
                         // householdIds present but unchanged from stored value
                         (resource.data.keys().hasAll(['householdIds'])
                          && request.resource.data.householdIds == resource.data.householdIds)
                         ||
                         // householdIds not in stored doc yet — allow only empty list
                         (!resource.data.keys().hasAll(['householdIds'])
                          && request.resource.data.householdIds == [])
                       );
      allow delete: if false;
    }

    match /households/{householdId} {
      allow read: if belongsToHousehold(householdId);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      // FIX: Prevent owner from locking themselves out by modifying ownerUid
      allow update: if signedIn() && resource.data.ownerUid == request.auth.uid &&
                    request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /medicines/{medicineId} {
      allow read: if belongsToHousehold(resource.data.householdId);
      allow create: if belongsToHousehold(request.resource.data.householdId);
      // FIX: Prevent transferring medicines between households
      allow update: if belongsToHousehold(resource.data.householdId) && 
                    request.resource.data.householdId == resource.data.householdId;
      allow delete: if belongsToHousehold(resource.data.householdId);
    }

    match /reminders/{reminderId} {
      allow read: if belongsToHousehold(resource.data.householdId);
      allow create: if belongsToHousehold(request.resource.data.householdId);
      // FIX: Prevent transferring reminders
      allow update: if belongsToHousehold(resource.data.householdId) && 
                    request.resource.data.householdId == resource.data.householdId;
      allow delete: if belongsToHousehold(resource.data.householdId);
    }

    match /members/{memberId} {
      allow read: if belongsToHousehold(resource.data.householdId);
      allow create: if belongsToHousehold(request.resource.data.householdId);
      // FIX: Prevent transferring members
      allow update: if belongsToHousehold(resource.data.householdId) && 
                    request.resource.data.householdId == resource.data.householdId;
      allow delete: if belongsToHousehold(resource.data.householdId);
    }

    match /caregivers/{caregiverId} {
      allow read: if belongsToHousehold(resource.data.householdId);
      allow create: if belongsToHousehold(request.resource.data.householdId);
      // FIX: Prevent transferring caregivers
      allow update: if belongsToHousehold(resource.data.householdId) && 
                    request.resource.data.householdId == resource.data.householdId;
      allow delete: if belongsToHousehold(resource.data.householdId);
    }
  }
}
