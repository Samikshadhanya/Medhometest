# v0 sandbox internal files
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
.vercel/

# Environment variables — NEVER commit these
.env*.local
.env

# Test config with tokens — local only
input.json

# Temp service account file generated by deploy_rules.py — contains private key
service_account_tmp.json
automated_test/build_sa.py

# Vulnerability / test reports — contain tokens & findings, keep local
automated_test/report.json
automated_test/secret_scan_results.json
automated_test/*.xlsx

# Common ignores
node_modules
.next/
data/
.DS_Store
*.log
*.tsbuildinfo

# Android build artifacts — generated by `npm run build && npx cap sync android`
# DO NOT commit — these embed NEXT_PUBLIC_ env vars and bloat the repo
android/app/build/
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
